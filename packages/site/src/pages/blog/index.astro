---
import { getCollection } from "astro:content";
import Layout from "#layouts/Default.astro";
import { PostGrid, PostItem } from "@aelar/atoms";
import BlogSummaryCard from "@aelar/components/blog/BlogSummaryCard.astro";

const posts = await getCollection("blog").then((collection) =>
  collection.toSorted(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
  ),
);
---

<Layout title="Blog" description="Blog | Here's my blog!" pageTitle="Blog">
  <main class="bg-green p-6">
    <PostGrid>
      {
        posts.map((post) => (
          <PostItem>
            <BlogSummaryCard post={post} context={{ baseUrl: "/blog" }} />
          </PostItem>
        ))
      }
    </PostGrid>
  </main>
</Layout>
