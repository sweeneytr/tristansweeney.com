---
import Layout from "@layouts/Default.astro";

import Card from "@aelar/components/atoms/Card.astro";
import Education from "@aelar/components/resume/education.astro";
import Experience from "@aelar/components/resume/experience.astro";
import Expertise from "@aelar/components/resume/expertise.astro";
import CopyResumeLinkButton from "@aelar/components/resume/copyResumeLinkButton.astro";
import DownloadResumeButton from "@aelar/components/resume/downloadResumeButton.astro";
import Button from "@aelar/components/atoms/Button.astro";
import InfoIcon from "@aelar/components/atoms/icons/InfoIcon.astro";
---

<Layout
  title="Tristan Sweeney"
  pageTitle="Tristan Sweeney | Home"
  description="Hi! I'm Tristan. I write software for fun, and also to get paid"
  classList="flex flex-col min-h-screen"
>
  <main class="bg-indigo flex grow flex-col items-center">
    <Button class="bg-emerald m-4 p-4" href="/resume">
      <div class="flex flex-row items-center gap-2">
        <InfoIcon class="h-8 w-8" />
        <div>Click here for the serious version.</div>
      </div>
    </Button>

    <section
      id="resume"
      class="mx-4 flex w-full flex-col items-stretch px-4 sm:mx-0 sm:w-3/4"
    >
      <div class="mb-8 flex flex-col items-center gap-8">
        <Experience />
        <div class="flex grid-cols-3 flex-col items-start gap-8 sm:grid">
          <Education />
          <Expertise class="col-span-2" />
        </div>
      </div>
    </section>

    <div class="sticky bottom-0">
      <Card
        class="bg-emerald m-4 mt-0 flex flex-row items-center justify-center gap-8 px-8"
      >
        <CopyResumeLinkButton />
        <DownloadResumeButton />
      </Card>
    </div>
  </main>
</Layout>
