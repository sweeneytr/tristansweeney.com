---
import Layout from "#layouts/Default.astro";

import { Card } from "@aelar/atoms";
import DownloadResumeButton from "#components/resume/downloadResumeButton.astro";
import SeriousExperience from "#components/resume/seriousExperience.astro";
import SeriousEducation from "#components/resume/seriousEducation.astro";
import SeriousExpertise from "#components/resume/seriousExpertise.astro";
---

<Layout
  title="Tristan Sweeney"
  pageTitle="Tristan Sweeney | Home"
  description="Hi! I'm Tristan. I write software for fun, and also to get paid"
  classList="flex flex-col min-h-screen"
>
  <main
    class="flex grow flex-col items-center bg-white"
    style="background-image: url('circuit-board.svg'); background-repeat: repeat;"
  >
    <section
      id="resume"
      class="mt-4 flex w-full flex-col items-stretch px-4 sm:mx-8"
    >
      <div class="flex flex-col items-center">
        <Card
          class="mb-8 flex w-full flex-col items-center gap-8 bg-white p-4 sm:w-4xl"
        >
          <SeriousExperience />
          <SeriousEducation />
          <SeriousExpertise />
        </Card>
      </div>
    </section>

    <div class="sticky bottom-0 flex w-full flex-row-reverse md:justify-center">
      <DownloadResumeButton class="m-8 mt-0 rounded" />
    </div>
  </main>
</Layout>
